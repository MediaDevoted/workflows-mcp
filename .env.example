# Workflows MCP — copy to .env and fill in values

# ─── Transport ───────────────────────────────────────────────────────────────
WORKFLOWS_MCP_TRANSPORT=http
WORKFLOWS_MCP_PORT=3030
WORKFLOWS_MCP_AUTH_TOKEN=
MCP_AUTH_TOKEN=

# ─── Agent Platform (workflows live here) ────────────────────────────────────
AGENT_PLATFORM_URL=http://localhost:7992
AGENT_PLATFORM_SYNC_KEY=
AGENT_PLATFORM_API_KEY=

# ─── Employee API (RBAC + audit) ─────────────────────────────────────────────
EMPLOYEE_API_URL=http://localhost:7991
MCP_SYNC_API_KEY=
EMPLOYEE_AUTH_DISABLED=false
EMPLOYEE_AUTH_CACHE_SECONDS=30
WORKFLOWS_READ_PERMISSION=WORKFLOWS_READ
WORKFLOWS_WRITE_PERMISSION=MANAGE_WORKFLOWS
WORKFLOWS_ADMIN_PERMISSIONS=MANAGE_WORKFLOWS,MANAGE_ACCESS,MANAGE_SETTINGS

# ─── Audit ───────────────────────────────────────────────────────────────────
AUDIT_TRAIL_URL=

# ─── Catalog sync scope ──────────────────────────────────────────────────────
MCP_ALLOWED_TEAMS=

# ─── Tuning ──────────────────────────────────────────────────────────────────
RESPONSE_MAX_BYTES=200000

# ─── Semantic search (OpenAI embeddings + pgvector) ──────────────────────────
# When OPENAI_API_KEY is unset, workflows_search degrades to literal trigger ranking.
OPENAI_API_KEY=
EMBEDDINGS_DB_PASSWORD=
EMBEDDINGS_DB_URL=postgres://workflows:placeholder@workflows-mcp-pgvector:5432/embeddings
EMBEDDINGS_SYNC_INTERVAL_MS=300000
EMBEDDINGS_BATCH_SIZE=50
