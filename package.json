{
  "name": "workflows-mcp",
  "version": "0.1.0",
  "description": "Hermes-optimized MCP server for governed access to MediaDevoted workflow playbooks via the agent-platform Workflows API.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "workflows-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/**/*.test.ts"
  },
  "keywords": [
    "mcp",
    "hermes",
    "workflows",
    "playbooks",
    "rbac",
    "audit"
  ],
  "license": "MIT",
  "dependencies": {
    "@mediadevoted/mcp-passthrough": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "pg": "^8.13.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
